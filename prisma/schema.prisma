generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SeenMatch {
  dbId        Int      @id @default(autoincrement())
  matchId     String
  homeTeam    String
  awayTeam    String
  matchDate   String
  matchTime   String
  competition String
  ticketUrl   String
  status      String   @default("")
  seenAt      DateTime @default(now())

  @@index([matchId])
  @@map("seen_matches")
}
